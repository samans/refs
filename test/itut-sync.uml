        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="_CTcaEMCKEe6csOUPxtf2vA" name="SynPhyLineClockPortPac">
        <ownedComment xmi:type="uml:Comment" xmi:id="_HixlsMCKEe6csOUPxtf2vA" annotatedElement="_CTcaEMCKEe6csOUPxtf2vA">
          <body>The SyncPhy Line Clock Port attributes.</body>
        </ownedComment>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_sovywMCKEe6csOUPxtf2vA" name="lineClockTmMode">
          <ownedComment xmi:type="uml:Comment" xmi:id="__BBKkMCKEe6csOUPxtf2vA" annotatedElement="_sovywMCKEe6csOUPxtf2vA">
            <body>Indicates whether to use the Timing Marker (TM) code or the Synchronization Status Message (SSM) code.&#xD;
&#xD;
When set to FALSE, the SSM code is used.&#xD;
&#xD;
When set to TRUE, the TM code is used.</body>
