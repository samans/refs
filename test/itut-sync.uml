        <ownedAttribute xmi:type="uml:Property" xmi:id="_BXiDkPuxEeyYWcp8834_4g" name="meanPathDelay" type="_gaPGoPuxEeyYWcp8834_4g">
          <ownedComment xmi:type="uml:Comment" xmi:id="_Q4KqcPuyEeyYWcp8834_4g" annotatedElement="_BXiDkPuxEeyYWcp8834_4g">
            <body>The definition of the meanPathDelay has been retained in IEEE 1588-2019 &#xD;
but renamed as meanDelay: to confirm that there is a need to keep this attribute &#xD;
for IEEE 1588-2008 based implementations or use the meanDelay attribute instead.&#xD;
To be reconciled also with P1588e.&#xD;
&#xD;
The calculated value of the mean propagation time.&#xD;
&#xD;
This attribute has been deprecated by the meanDelay for IEEE 1588-2019 based implementations.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_DieRIPuxEeyYWcp8834_4g" name="meanDelay" type="_gaPGoPuxEeyYWcp8834_4g">
