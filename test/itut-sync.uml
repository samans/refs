            <body>The Sa bit of an input SyncPhy Port which is used to carry the Synchronization Status Message (SSM) codes.</body>
          </ownedComment>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_OxBe4OdgEe-_EIe4GGpy2Q"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_JOmtsL9_Ee6xirORnB-xqg" name="ssmOutSaBit" type="_op40MMuFEe6jTarIgt-ZIw">
          <ownedComment xmi:type="uml:Comment" xmi:id="_JOmtsb9_Ee6xirORnB-xqg" annotatedElement="_JOmtsL9_Ee6xirORnB-xqg">
            <body>The Sa bit of an output SyncPhy Port which is used to carry the Synchronization Status Message (SSM) codes.</body>
          </ownedComment>
