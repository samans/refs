            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci2ZwWEfC2s4m-Mpzytw" annotatedElement="_8bci2JwWEfC2s4m-Mpzytw">
              <body>The priority1 attribute of the local clock.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci2pwWEfC2s4m-Mpzytw" name="priority2">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci25wWEfC2s4m-Mpzytw" annotatedElement="_8bci2pwWEfC2s4m-Mpzytw">
              <body>The priority2 attribute of the local clock.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci3JwWEfC2s4m-Mpzytw" name="clockQuality" type="_7uCVMPuUEeyYWcp8834_4g">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci3ZwWEfC2s4m-Mpzytw" annotatedElement="_8bci3JwWEfC2s4m-Mpzytw">
              <body>The clock quality of the PTP Instance.</body>
            </ownedComment>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci3pwWEfC2s4m-Mpzytw" name="twoStepFlag" isReadOnly="true">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci35wWEfC2s4m-Mpzytw" annotatedElement="_8bci3pwWEfC2s4m-Mpzytw">
              <body>When set to True, the PTP Instance is two-step, otherwise the PTP Instance is one-step.</body>
            </ownedComment>
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci4JwWEfC2s4m-Mpzytw" annotatedElement="_8bci3pwWEfC2s4m-Mpzytw">
              <body>Pending confirmation by Q13/15 that the twoStepFlag DS member should be configurable also for the PTP telecom profile implementations based on IEEE 1588-2019.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci4ZwWEfC2s4m-Mpzytw" name="numberPorts" isReadOnly="true">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci4pwWEfC2s4m-Mpzytw" annotatedElement="_8bci4ZwWEfC2s4m-Mpzytw">
              <body>The number of PTP Ports on the PTP Instance.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci45wWEfC2s4m-Mpzytw" name="sdoId">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci5JwWEfC2s4m-Mpzytw" annotatedElement="_8bci45wWEfC2s4m-Mpzytw">
              <body>The value of the sdoId attribute of the domain.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci5ZwWEfC2s4m-Mpzytw" name="maxStepsRemoved">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci5pwWEfC2s4m-Mpzytw" annotatedElement="_8bci5ZwWEfC2s4m-Mpzytw">
              <body>The value used by the PTP Instance to qualify (or not) received Announce messages in the operation of the Best TimeTransmitter Clock Algorithm (BTCA).</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          </ownedAttribute>
          <ownedAttribute xmi:type="uml:Property" xmi:id="_8bci55wWEfC2s4m-Mpzytw" name="instanceEnable">
            <ownedComment xmi:type="uml:Comment" xmi:id="_8bci6JwWEfC2s4m-Mpzytw" annotatedElement="_8bci55wWEfC2s4m-Mpzytw">
              <body>Indicates whether the PTP Instance is enabled (or not) for PTP operation.</body>
            </ownedComment>
            <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
          </ownedAttribute>
        </nestedClassifier>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="_xFukoD19Ee2W1rFizNp8rQ" name="PtpTlpPortDsPac" isAbstract="true">
        <ownedComment xmi:type="uml:Comment" xmi:id="_jOLJgD1-Ee2W1rFizNp8rQ" annotatedElement="_xFukoD19Ee2W1rFizNp8rQ">
          <body>The additional Port data set (DS) members of the PTP Telecom Profile Port.</body>
        </ownedComment>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_FdSicAJ3EeetMLWdj1z_Ew" name="ptpUdpEgressConfiguration" type="_MMWWcAeQEeeSr90X-zum4Q">
          <ownedComment xmi:type="uml:Comment" xmi:id="_w-vhkAfPEeexrILJlIcylA" annotatedElement="_FdSicAJ3EeetMLWdj1z_Ew">
            <body>The configuration of PTP UDP encapsulation, including destination IP address and IPv4/IPv6 protocol.&#xD;
&#xD;
Editors' Note: No corresponding DS member has been defined in ITU-T Q13/15 Recommendations.&#xD;
&#xD;
Q13/15 feedbacks: UDP is initiated by the slave, at some point the slave address will be known by the master&#xD;
There are datasets related to unicast negotiation in IEEE 1588. PTP is agnostic regarding IPv6 and IPv4.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_X5szYAJ3EeetMLWdj1z_Ew" name="ptpMacEgressConfiguration" type="_I0MUAAJPEeegkdv_tKLxWg">
          <ownedComment xmi:type="uml:Comment" xmi:id="_xq414AfPEeexrILJlIcylA" annotatedElement="_X5szYAJ3EeetMLWdj1z_Ew">
            <body>The configuration of PTP MAC encapsulation, including destination MAC address.&#xD;
&#xD;
Editors' Note: No corresponding DS member has been defined in ITU-T Q13/15 Recommendations.&#xD;
&#xD;
Q13/15 feedbacks: the only point of interest for Q13 is the forwardable and non-forwardable multicast addresses.&#xD;
The choice is made by configuration per port basis.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_rGAVYFpJEeeEToh03JBYQA" name="localPriority">
          <ownedComment xmi:type="uml:Comment" xmi:id="_9uqSkFpJEeeEToh03JBYQA" annotatedElement="_rGAVYFpJEeeEToh03JBYQA">
            <body>The local priority assigned to the PTP Port and used by the Best TimeTransmitter Clock Algorithm (BTCA).</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_RwVK4D2EEe2W1rFizNp8rQ" name="sf" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_dmECwD2EEe2W1rFizNp8rQ" annotatedElement="_RwVK4D2EEe2W1rFizNp8rQ">
            <body>Indicates whether the clock generates (or not) a state decision event when the beginning or the end of a Packet Timing Signal Fail (PTSF) condition occurs at the PTP Port.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_GPgLYAGCEe-e29a165jOaw" name="syncReceiptTimeout">
          <ownedComment xmi:type="uml:Comment" xmi:id="_BUdYQAGDEe-e29a165jOaw" annotatedElement="_GPgLYAGCEe-e29a165jOaw">
            <body>The number of Sync message intervals that have to pass without receipt of a Sync or a Follow-up message before the triggering the Packet Timing Signal Fail lossOfTimingMessages (PTSF-LOTM).</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_I1AOAAGCEe-e29a165jOaw" name="delayRespReceiptTimeout">
          <ownedComment xmi:type="uml:Comment" xmi:id="_xo8-8AikEe-L26HlaNJDVg" annotatedElement="_I1AOAAGCEe-e29a165jOaw">
            <body>The number of Delay_Req message intervals that have to pass without receipt of a Delay_Resp message before triggering timeout period for reception of Delay_Resp messages used to trigger the Packet Timing Signal Fail lossOfTimingMessages (PTSF-LOTM).</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_Lcd_gAGCEe-e29a165jOaw" name="notTimeTransmitter">
          <ownedComment xmi:type="uml:Comment" xmi:id="_b3xe4AGDEe-e29a165jOaw" annotatedElement="_Lcd_gAGCEe-e29a165jOaw">
            <body>When set to True, the PTP Port can never enter the PRE_TIME_TRANSMITTER or the TIME_TRANSMITTER state, and, if the recommended state by the Alternate Best TimeTransmitter Clock Algorithm (BTCA) is BTC_ TIME_TRANSMITTER, then the PTP Port should instead be placed in the PASSIVE state.&#xD;
&#xD;
Setting both the timeTrasmitterOnly and the notTimeTransmitter to True is not allowed.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_OEubMAGCEe-e29a165jOaw" name="monitorSender">
          <ownedComment xmi:type="uml:Comment" xmi:id="_sK_OsAGDEe-e29a165jOaw" annotatedElement="_OEubMAGCEe-e29a165jOaw">
            <body>This attribute is used together with the monitorReceiver attribute in the peer PTP Port, to enable the monitoring of the alternate timeTransmitter time information provided by a peer PTP Port, as shown in Table G-1 of ITU-T G.8275.1.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_Qg47oAGCEe-e29a165jOaw" name="monitorReceiver">
          <ownedComment xmi:type="uml:Comment" xmi:id="_9L7AIAGDEe-e29a165jOaw" annotatedElement="_Qg47oAGCEe-e29a165jOaw">
            <body>This attribute is used together with the monitorSender attribute in the peer PTP Port, to enable the monitoring of the alternate timeTransmitter time information provided by a peer PTP Port, as shown in Table G-1 of ITU-T G.8275.1.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_WfK38AGCEe-e29a165jOaw" name="sfUnusable" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_ncrQAAGEEe-e29a165jOaw" annotatedElement="_WfK38AGCEe-e29a165jOaw">
            <body>Indicates whether the Packet Timing Signal Fail unusable (PTSF-unusable) condition is detected or cleared.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_aSCFkAGCEe-e29a165jOaw" name="sfSu" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_5SR_oAGEEe-e29a165jOaw" annotatedElement="_aSCFkAGCEe-e29a165jOaw">
            <body>Indicates whether the Packet Timing Signal Fail synchronizationUncertain (PTSF-SU) condition is detected or cleared.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_IuVT0BIhEe-aAcddIn44RQ" name="sfLotm" visibility="public" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_xzT3oBIiEe-aAcddIn44RQ" annotatedElement="_IuVT0BIhEe-aAcddIn44RQ">
            <body>Indicates whether the Packet Timing Signal Fail lossOfTimingMessages (PTSF-LOTM) condition is detected or cleared.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_YeKL4CfcEe-YtLpWvFpwhg" name="twoStepFlag" visibility="public" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_r3D6QCfcEe-YtLpWvFpwhg" annotatedElement="_YeKL4CfcEe-YtLpWvFpwhg">
            <body>When set to True, the PTP Port is two-step, otherwise the PTP Port is one-step.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_kwzt8DyQEe-nEP0EFGHiZg" name="wtrState" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_kwzt8TyQEe-nEP0EFGHiZg" annotatedElement="_kwzt8DyQEe-nEP0EFGHiZg">
            <body>Reports whether the PTP Port is in the wait-to-restore (WTR) state, or not.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Boolean"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_iMET0C3tEfGX7Jwr7U0FeQ" name="wtrRemainingTime" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_NzWRwC3uEfGX7Jwr7U0FeQ" annotatedElement="_iMET0C3tEfGX7Jwr7U0FeQ">
            <body>The remaining time before the wait-to-restore (WTR) time expires.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_A9YE4C3uEfGX7Jwr7U0FeQ"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_q0PDgi3tEfGX7Jwr7U0FeQ" name="_localTimeReference" type="_oH-4oC3tEfGX7Jwr7U0FeQ" isReadOnly="true" aggregation="composite" association="_q0OccC3tEfGX7Jwr7U0FeQ">
          <ownedComment xmi:type="uml:Comment" xmi:id="_Vi7MkC3uEfGX7Jwr7U0FeQ" annotatedElement="_q0PDgi3tEfGX7Jwr7U0FeQ">
            <body>The additional Port data set (DS) members of the PTP Telecom Profile Port connected to end application with local time reference (LTR).</body>
          </ownedComment>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_q0St4S3tEfGX7Jwr7U0FeQ"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_q0St4i3tEfGX7Jwr7U0FeQ" value="1"/>
        </ownedAttribute>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="_iiPfwK9kEeyhFvM20gSYXA" name="PtpTlpDefaultDsPac" isAbstract="true">
        <ownedComment xmi:type="uml:Comment" xmi:id="_FcZT4BIfEe-aAcddIn44RQ" annotatedElement="_iiPfwK9kEeyhFvM20gSYXA">
          <body>The additional Default data set (DS) members of the PTP Telecom Profile Instance.</body>
        </ownedComment>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_McgzoAJREeegkdv_tKLxWg" name="deviceType" type="_Yf7i8K-IEeyhFvM20gSYXA">
          <ownedComment xmi:type="uml:Comment" xmi:id="_rtaAQAfOEeexrILJlIcylA" annotatedElement="_McgzoAJREeegkdv_tKLxWg">
            <body>The device type for the PTP Telecom Profile Instance.&#xD;
&#xD;
The PTP Telecom Profile of the PTP Instance qualifies whether the type is a G.8265.1_DeviceType or a G.8275.1_DeviceType or a G.8275.2_DeviceType.&#xD;
&#xD;
Editors' Note: To further investigate whether this attribute can be re-configured after the PTP Instance has been created.&#xD;
&#xD;
Note that this pending issue has no impact on the YANG models defined in G.7721.1.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_notB0PuYEeyYWcp8834_4g" name="localPriority">
          <ownedComment xmi:type="uml:Comment" xmi:id="_qGDOAPuYEeyYWcp8834_4g" annotatedElement="_notB0PuYEeyYWcp8834_4g">
            <body>The local priority assigned to the PTP Instance and used by the Best TimeTransmitter Clock Algorithm (BTCA).</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_QV7TgPK1Ee6khsQrNUrTqg" name="profileIdentifier" type="_tKUr8PK1Ee6khsQrNUrTqg">
          <ownedComment xmi:type="uml:Comment" xmi:id="_fn82oPK2Ee6khsQrNUrTqg" annotatedElement="_QV7TgPK1Ee6khsQrNUrTqg">
            <body>The PTP Telecom Profile which applies to the PTP Instance.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_pE20gDx5Ee-nEP0EFGHiZg" name="holdoverWithinSpecDuration">
          <ownedComment xmi:type="uml:Comment" xmi:id="_pE20gTx5Ee-nEP0EFGHiZg" annotatedElement="_pE20gDx5Ee-nEP0EFGHiZg">
            <body>The duration of the holdover-within-specification mode.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_pE-JQDx5Ee-nEP0EFGHiZg" name="holdoverWithinSpecTimeErrorThreshold">
          <ownedComment xmi:type="uml:Comment" xmi:id="_pE-JQTx5Ee-nEP0EFGHiZg" annotatedElement="_pE-JQDx5Ee-nEP0EFGHiZg">
            <body>The Time Error threshold of the holdover-within-specification mode.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_pE_XYDx5Ee-nEP0EFGHiZg" name="holdoverWithinSpecCapability" type="_XAda8Dx5Ee-nEP0EFGHiZg" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_pE_XYTx5Ee-nEP0EFGHiZg" annotatedElement="_pE_XYDx5Ee-nEP0EFGHiZg">
            <body>The modes supported by the equipment for the holdover-within-specification behaviour.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_pFAlgDx5Ee-nEP0EFGHiZg" name="holdoverWithinSpecRemainingDuration" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_pFAlgTx5Ee-nEP0EFGHiZg" annotatedElement="_pFAlgDx5Ee-nEP0EFGHiZg">
            <body>The estimation of the remaining duration during the holdover-within-specification mode.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_pFBzoDx5Ee-nEP0EFGHiZg" name="wtrTime" visibility="public">
          <ownedComment xmi:type="uml:Comment" xmi:id="_pFBzoTx5Ee-nEP0EFGHiZg" annotatedElement="_pFBzoDx5Ee-nEP0EFGHiZg">
            <body>The wait-to-restore (WTR) time.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_VPWLMDyQEe-nEP0EFGHiZg" name="clockMode" isLeaf="true" type="_2POFYI9tEe-lbv_Bmlne1g" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_VPWLMTyQEe-nEP0EFGHiZg" annotatedElement="_VPWLMDyQEe-nEP0EFGHiZg">
            <body>The synchonization mode of the clock.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_VPXZUDyQEe-nEP0EFGHiZg" name="nodeClass" type="_oZ9bbjyPEe-nEP0EFGHiZg">
          <ownedComment xmi:type="uml:Comment" xmi:id="_VPXZUTyQEe-nEP0EFGHiZg" annotatedElement="_VPXZUDyQEe-nEP0EFGHiZg">
            <body>The clock node's time error performance compliance.&#xD;
&#xD;
This attribute applies only to G.8275.1 and G.8275.2 PTP Telecom Profile Instances.&#xD;
&#xD;
The profile attribute qualifies whether the node class is a G.8275.1 or a G.8275.2 node class.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_WeXTYC3pEfGX7Jwr7U0FeQ" name="timeSinceCurrentClockMode" visibility="public" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_CcQagC3qEfGX7Jwr7U0FeQ" annotatedElement="_WeXTYC3pEfGX7Jwr7U0FeQ">
            <body>The time elapsed in the current clock mode.</body>
          </ownedComment>
          <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Integer"/>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_zreGwC3pEfGX7Jwr7U0FeQ"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_eYeDMC3pEfGX7Jwr7U0FeQ" name="_localTimeReference" type="_cxxLIC3pEfGX7Jwr7U0FeQ" aggregation="composite" association="_eYc1EC3pEfGX7Jwr7U0FeQ">
          <ownedComment xmi:type="uml:Comment" xmi:id="_JTMdIC3qEfGX7Jwr7U0FeQ" annotatedElement="_eYeDMC3pEfGX7Jwr7U0FeQ">
            <body>The additional Default data set (DS) members of the PTP Telecom Profile Instance in an end application with local time reference (LTR).</body>
          </ownedComment>
          <lowerValue xmi:type="uml:LiteralInteger" xmi:id="_eYhtkS3pEfGX7Jwr7U0FeQ"/>
          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_eYiUoC3pEfGX7Jwr7U0FeQ" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ppJGMC3pEfGX7Jwr7U0FeQ" name="forcedClockQuality" type="_uYDlAC3sEfGX7Jwr7U0FeQ">
