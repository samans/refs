          <ownedComment xmi:type="uml:Comment" xmi:id="_XAda-Tx5Ee-nEP0EFGHiZg" annotatedElement="_XAda-Dx5Ee-nEP0EFGHiZg">
            <body>The implementation supports only holdoverWithinSpecificationTimeErrorThreshold mode.</body>
