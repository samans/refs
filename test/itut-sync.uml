            <body>The source of the signal for the station clock output (see selector C of Figure A.2).</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_z5K-UMCIEe6csOUPxtf2vA" name="stationClockOutputSourceID" type="_Yj0dwMA7Ee6xirORnB-xqg" isReadOnly="true">
