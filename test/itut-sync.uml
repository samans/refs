            <body>The clock type of the SyncPhy Station Clock Port.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_FOGFUAJ2EeetMLWdj1z_Ew" name="stationClockSsmOutThreshold" type="_m1DF0MtXEe-IysdZWZ9W1Q">
