            <body>The Quality Level (QL) value at input.</body>
          </ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_BvE7AMCFEe6csOUPxtf2vA" name="qlOutputInfo" type="_m1DF0MtXEe-IysdZWZ9W1Q" isReadOnly="true">
          <ownedComment xmi:type="uml:Comment" xmi:id="_JoNacMCFEe6csOUPxtf2vA" annotatedElement="_BvE7AMCFEe6csOUPxtf2vA">
            <body>The current output Synchronization Status Message (SSM) quality level of the SyncPhy Port.</body>
          </ownedComment>
        </ownedAttribute>
