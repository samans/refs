          <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_NXJYEMCKEe6csOUPxtf2vA" value="1"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ge5o4MCGEe6csOUPxtf2vA" name="_stationClockPort" type="_NVTh0MCGEe6csOUPxtf2vA" aggregation="composite" association="_gev34MCGEe6csOUPxtf2vA">
