          <body>The port data set (DS) of the SyncPhy Port.</body>
        </ownedComment>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_1wQcwMB9Ee6csOUPxtf2vA" name="portName" visibility="public" isReadOnly="true">
