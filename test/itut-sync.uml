        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="_XAda-zx5Ee-nEP0EFGHiZg" name="DURATION_AND_TIME_ERROR_THRESHOLD">
          <ownedComment xmi:type="uml:Comment" xmi:id="_XAda_Dx5Ee-nEP0EFGHiZg" annotatedElement="_XAda-zx5Ee-nEP0EFGHiZg">
            <body>The implementation supports both the holdoverWithinSpecificationDuration and the holdoverWithinSpecificationTimeErrorThreshold modes.</body>
          </ownedComment>
          <specification xmi:type="uml:LiteralInteger" xmi:id="_XAda_Tx5Ee-nEP0EFGHiZg" value="3"/>
        </ownedLiteral>
      </packagedElement>
