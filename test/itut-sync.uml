          <ownedComment xmi:type="uml:Comment" xmi:id="_XAda8zx5Ee-nEP0EFGHiZg" annotatedElement="_XAda8jx5Ee-nEP0EFGHiZg">
            <body>The implementation does not support any of the modes.</body>
          </ownedComment>
          <specification xmi:type="uml:LiteralInteger" xmi:id="_XAda9Dx5Ee-nEP0EFGHiZg"/>
        </ownedLiteral>
        <ownedLiteral xmi:type="uml:EnumerationLiteral" xmi:id="_XAda9Tx5Ee-nEP0EFGHiZg" name="DURATION">
          <ownedComment xmi:type="uml:Comment" xmi:id="_XAda9jx5Ee-nEP0EFGHiZg" annotatedElement="_XAda9Tx5Ee-nEP0EFGHiZg">
            <body>The implementation supports only the holdoverWithinSpecificationDuration mode.</body>
          </ownedComment>
